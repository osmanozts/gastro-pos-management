  "info": {
    "title": "Gastro POS API",
    "description": "Restaurant Bestellsystem",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Hauptgerichte"
          },
          "sortOrder": {
            "type": "number",
            "example": 0,
            "minimum": 0
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Hauptgerichte"
          },
          "sortOrder": {
            "type": "number",
            "example": 0,
            "minimum": 0
          }
        }
      },
      "CreateMenuItemDto": {
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "string",
            "example": "clx1234567890"
          },
          "name": {
            "type": "string",
            "example": "Pizza Margherita"
          },
          "description": {
            "type": "string",
            "example": "Klassiker mit Tomaten und Mozzarella"
          },
          "price": {
            "type": "number",
            "example": 11.5
          },
          "type": {
            "type": "string",
            "enum": [
              "MAIN",
              "DRINK",
              "ADDON",
              "TOPPING",
              "SIDE"
            ]
          },
          "available": {
            "type": "boolean",
            "example": true
          },
          "sortOrder": {
            "type": "number",
            "example": 0,
            "minimum": 0
          }
        },
        "required": [
          "categoryId",
          "name",
          "price",
          "type"
        ]
      },
      "UpdateMenuItemDto": {
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "string",
            "example": "clx1234567890"
          },
          "name": {
            "type": "string",
            "example": "Pizza Margherita"
          },
          "description": {
            "type": "string",
            "example": "Klassiker mit Tomaten und Mozzarella"
          },
          "price": {
            "type": "number",
            "example": 11.5
          },
          "type": {
            "type": "string",
            "enum": [
              "MAIN",
              "DRINK",
              "ADDON",
              "TOPPING",
              "SIDE"
            ]
          },
          "available": {
            "type": "boolean",
            "example": true
          },
          "sortOrder": {
            "type": "number",
            "example": 0,
            "minimum": 0
          }
        }
      },
      "CreateTableDto": {
        "type": "object",
        "properties": {
          "number": {
            "type": "number",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Tisch am Fenster"
          },
          "capacity": {
            "type": "number",
            "example": 4,
            "minimum": 1
          }
        },
        "required": [
          "number",
          "capacity"
        ]
      },
      "UpdateTableDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Tisch am Fenster"
          },
          "capacity": {
            "type": "number",
            "example": 4,
            "minimum": 1
          }
        }
      },
      "UpdateTableStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "FREE",
              "OCCUPIED",
              "PARTIALLY_PAID"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "tableId": {
            "type": "string",
            "example": "clx1234567890"
          },
          "notes": {
            "type": "string",
            "example": "Tisch am Fenster"
          }
        },
        "required": [
          "tableId"
        ]
      },
      "OrderItemDto": {
        "type": "object",
        "properties": {
          "menuItemId": {
            "type": "string",
            "example": "clx1234567890"
          },
          "lineType": {
            "type": "string",
            "enum": [
              "MAIN",
              "ADDON",
              "TOPPING",
              "DRINK",
              "SIDE"
            ]
          },
          "quantity": {
            "type": "number",
            "example": 1,
            "minimum": 1
          },
          "notes": {
            "type": "string",
            "example": "ohne Zwiebeln"
          },
          "parentId": {
            "type": "string",
            "example": "clx0987654321"
          }
        },
        "required": [
          "menuItemId",
          "lineType"
        ]
      },
      "AddOrderItemsDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemDto"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "UpdateOrderItemStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "CREATED",
              "SENT_TO_KITCHEN",
              "READY",
              "SERVED",
              "PAID"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "PaymentAllocationDto": {
        "type": "object",
        "properties": {
          "orderItemId": {
            "type": "string",
            "example": "clx1234567890"
          },
          "amount": {
            "type": "number",
            "example": 13.5,
            "minimum": 0.01
          }
        },
        "required": [
          "orderItemId",
          "amount"
        ]
      },
      "CreatePaymentDto": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "example": "clx1234567890"
          },
          "method": {
            "type": "string",
            "enum": [
              "CASH",
              "CARD"
            ]
          },
          "allocations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PaymentAllocationDto"
            }
          }
        },
        "required": [
          "orderId",
          "method",
          "allocations"
        ]
      }
    }
  }
}